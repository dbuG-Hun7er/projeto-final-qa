{
  "name": "projeto-final-qa",
  "version": "1.0.0",
  "private": true,
  "description": "Projeto final QA Automation com Cypress (UI) e Supertest/Mocha (API).",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run --headless",
    "ui:test": "npm run cy:run",
    "api:test": "npm --prefix api-tests test",
    "perf:coupons": "k6 run performance/k6/coupons_get.js",
    "perf:login": "k6 run performance/k6/login_smoke.js",
    "test": "npm run ui:test && npm run api:test"
  },
  "devDependencies": {
    "cypress": "^15.14.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "dotenv": "^17.4.2",
    "mocha": "^11.7.5",
    "supertest": "^7.2.2"
  }
}
